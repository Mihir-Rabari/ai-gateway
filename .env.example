# ═══════════════════════════════════════════════════════════
# AI Gateway — Environment Variables
# Copy this file to .env and fill in real values.
# This file is committed so the team has a known-good template;
# the REAL .env (with actual secrets) is git-ignored.
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=gateway_user
POSTGRES_PASSWORD=gateway_pass
POSTGRES_DB=ai_gateway

# ── ClickHouse ──────────────────────────────────────────────
CLICKHOUSE_DATABASE=ai_gateway_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── JWT Secrets (generated — rotate before going to prod) ───
JWT_ACCESS_SECRET=0546bb2334c5a13cc2b6ed05305d56999d33775bc218a768282d833770f78ce6bbcea385b2bf3ecdcebb48c184c8c4e14a3cbc07a3554b5e0a75e5ee46e14b57
JWT_REFRESH_SECRET=06c55fc0eb21f26401e5a0ec350b13421a7c6ec9a0e63ea660760f530a227cb7538b5018ae8df4dd9d02d7b79befd9ffb9bc417102750de4fd24c8f427984130

# ── Encryption Key (32-byte hex, for client secret storage) ─
CLIENT_SECRET_ENCRYPTION_KEY=bd8543feb1d6b45077af2d9172008d2643c29c96ead478b059cee9d4ef82f2a3

# ── AI Provider API Keys ─────────────────────────────────────
# Fill in your real keys — leave blank to run without a provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ── Razorpay (Billing) ───────────────────────────────────────
# Use test keys for local dev: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_MAX=
