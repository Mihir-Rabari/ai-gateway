# ═══════════════════════════════════════════════════════════════
# AI GATEWAY — Environment Variables
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# General
# ──────────────────────────────────────────────
NODE_ENV=development

# ──────────────────────────────────────────────
# PostgreSQL (Primary DB)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://gateway_user:gateway_pass@localhost:5432/ai_gateway
POSTGRES_USER=gateway_user
POSTGRES_PASSWORD=gateway_pass
POSTGRES_DB=ai_gateway

# ──────────────────────────────────────────────
# Redis (Cache + Sessions + Rate Limiting)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# NOTE: The redis container does not require a password by default in dev.
REDIS_PASSWORD=

# ──────────────────────────────────────────────
# Kafka (Event Streaming)
# ──────────────────────────────────────────────
# NOTE: Use localhost:9092 for host access to Kafka (e.g. running outside Docker)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ai-gateway
KAFKA_GROUP_ID=ai-gateway-group

# ──────────────────────────────────────────────
# ClickHouse (Analytics DB)
# ──────────────────────────────────────────────
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=ai_gateway_analytics

# ──────────────────────────────────────────────
# JWT Auth
# ──────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_EVENTS_CONSUMER_ENABLED=false
AUTH_AUDIT_CONSUMER_GROUP_ID=auth-service-audit-consumer

# ──────────────────────────────────────────────
# Razorpay (Payments)
# ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_PLAN_ID_PRO=plan_test_pro_xxxxxxxxxxxx
RAZORPAY_PLAN_ID_MAX=plan_test_max_xxxxxxxxxxxx

# ──────────────────────────────────────────────
# AI Providers
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
GOOGLE_AI_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# Service Ports
# ──────────────────────────────────────────────
API_PORT=3001
GATEWAY_PORT=3002
AUTH_SERVICE_PORT=3003
BILLING_SERVICE_PORT=3004
CREDIT_SERVICE_PORT=3005
ROUTING_SERVICE_PORT=3006
ANALYTICS_SERVICE_PORT=3007
WORKER_PORT=3008
# Frontend ports
WEB_PORT=3000
CONSOLE_PORT=3009

# ──────────────────────────────────────────────
# Internal Service URLs (used by service-to-service calls)
# ──────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3003
BILLING_SERVICE_URL=http://localhost:3004
CREDIT_SERVICE_URL=http://localhost:3005
ROUTING_SERVICE_URL=http://localhost:3006
ANALYTICS_SERVICE_URL=http://localhost:3007

# ──────────────────────────────────────────────
# Frontend / CORS
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3002
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3009
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3009

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ──────────────────────────────────────────────
# Credit Config
# ──────────────────────────────────────────────
FREE_PLAN_CREDITS=100
PRO_PLAN_CREDITS=1000
MAX_PLAN_CREDITS=5000
CREDIT_LOCK_TTL_SECONDS=30
